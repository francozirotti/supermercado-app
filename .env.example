# Copia este archivo a ".env" y completa tu API key de Anthropic.
# Se consigue en https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: modelo a usar para leer los tickets.
# claude-sonnet-4-6 = mejor precisión (recomendado)
# claude-haiku-4-5  = más barato, si subes muchos tickets al día
ANTHROPIC_MODEL=claude-sonnet-4-6

# Opcional: puerto donde corre la app
PORT=5000
